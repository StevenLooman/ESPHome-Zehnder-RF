# Gitignore settings for ESPHome
# This is an example and may include too much for your use-case.
# You can modify this file to suit your needs.
.esphome/
/secrets.yaml
.venv/

.build

# Soak/debug log captures
soak-*.log
verify-*.log
build-*.log
live-*.log

# Auto-generated by `esphome compile tests/ci.yaml` (root .gitignore already
# covers .esphome/ and secrets.yaml).
/tests/.gitignore

**/__pycache__
